<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NotePad Dashboard</title>
    <link rel="stylesheet" href="/stylesheets/dashboard.css">
    <script src="/javascripts/dashboard.js" defer></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <div class="logo">NotePad</div>
                <button class="new-note-btn" onclick="openModal()">
                    <span>+</span>
                    <span>New Note</span>
                </button>
            </div>

            <div class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Views</div>
                    <div class="nav-item active" onclick="filterNotes('all', this)">
                        <span class="nav-item-label">
                            <span>All Notes</span>
                        </span>
                        <span class="nav-item-count" id="allCount">0</span>
                    </div>
                    <div class="nav-item" onclick="filterNotes('pinned', this)">
                        <span class="nav-item-label">
                            <span>Pinned</span>
                        </span>
                        <span class="nav-item-count" id="pinnedCount">0</span>
                    </div>
                </div>

                <div class="nav-section">
                    <div class="nav-section-title">Categories</div>
                    <div class="nav-item" onclick="filterNotes('personal', this)">
                        <span class="nav-item-label">
                            <span>Personal</span>
                        </span>
                        <span class="nav-item-count" id="personalCount">0</span>
                    </div>
                    <div class="nav-item" onclick="filterNotes('work', this)">
                        <span class="nav-item-label">
                            <span>Work</span>
                        </span>
                        <span class="nav-item-count" id="workCount">0</span>
                    </div>
                    <div class="nav-item" onclick="filterNotes('ideas', this)">
                        <span class="nav-item-label">
                            <span>Ideas</span>
                        </span>
                        <span class="nav-item-count" id="ideasCount">0</span>
                    </div>
                    <div class="nav-item" onclick="filterNotes('todo', this)">
                        <span class="nav-item-label">
                            <span>To-Do</span>
                        </span>
                        <span class="nav-item-count" id="todoCount">0</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">U</div>
                    <div class="user-name">User</div>
                </div>
                <form action="/logout" method="POST" style ="display: inline;">
                    <button class="logout-btn" type="submit">Logout</button>
                </form>
                
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="main-header">
                <div class="search-container">
                    <input type="text" class="search-box" id="searchBox" placeholder="Search notes...">
                </div>
            </div>

            <div class="notes-area">
                <div class="notes-list" id="notesList"></div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal" id="noteModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="modalTitle">Create New Note</h2>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <form onsubmit="saveNote(event)">
                <div class="modal-body">
                    <div class="form-group">
                        <label>Title</label>
                        <input type="text" id="noteTitle" required placeholder="Untitled">
                    </div>
                    <div class="form-group">
                        <label>Category</label>
                        <select id="noteCategory">
                            <option value="personal">Personal</option>
                            <option value="work">Work</option>
                            <option value="ideas">Ideas</option>
                            <option value="todo">To-Do</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Content</label>
                        <textarea id="noteContent" required placeholder="Start writing..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                    <button type="submit" class="btn-save">Save Note</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>